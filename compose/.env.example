# Bloodbank sandbox — environment overrides
#
# Copy to `.env` (in the same directory) to customize ports and secrets.
# Run the sandbox with:
#
#   docker compose \
#     --project-name bloodbank \
#     --env-file compose/.env \
#     -f compose/docker-compose.yml \
#     up -d
#
# All variables are OPTIONAL. If unset, the compose file uses the defaults
# shown below.

# =============================================================================
# Port overrides (host-side)
# =============================================================================

# NATS client port. Container-internal port is always 4222.
BLOODBANK_NATS_CLIENT_PORT=4222

# NATS monitor / healthz port. Container-internal port is always 8222.
BLOODBANK_NATS_MONITOR_PORT=8222

# Dapr placement gRPC port.
BLOODBANK_DAPR_PLACEMENT_PORT=50005

# Apicurio Registry HTTP port.
BLOODBANK_APICURIO_PORT=8080

# EventCatalog HTTP port.
BLOODBANK_EVENTCATALOG_PORT=3000

# =============================================================================
# Secrets (Dapr secretstore.local.env lookup)
# =============================================================================
#
# The Dapr secret store component at components/secretstore.yaml is
# configured with `prefix: BLOODBANK_`. A secretKeyRef of
# `{ name: nats-token, key: nats-token }` resolves to the env var
# `BLOODBANK_nats-token`.
#
# Local sandbox: NATS is configured without auth, so these can stay empty.
# Do NOT commit populated values to the repo.

BLOODBANK_nats-token=
BLOODBANK_nats-seed-key=
