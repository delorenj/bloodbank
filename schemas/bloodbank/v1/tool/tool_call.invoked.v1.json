{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/tool/tool_call.invoked.v1.json",
  "title": "Tool Tool call Invoked Event",
  "description": "A tool call was invoked by the runtime (mid-execution). See bloodbank/docs/event-naming.md.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.tool.tool_call.invoked"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "tool"
    },
    "data": {
      "type": "object",
      "description": "Payload for bloodbank.v1.tool.tool_call.invoked.",
      "properties": {
        "invocation_id": {
          "type": "string",
          "minLength": 1
        },
        "tool_call_id": {
          "type": "string",
          "minLength": 1
        },
        "tool_name": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "invocation_id",
        "tool_call_id",
        "tool_name"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "type",
    "kind",
    "domain",
    "data"
  ]
}
