{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/cli/stderr.appended.v1.json",
  "title": "Cli Stderr Appended Event",
  "description": "A chunk of stderr was emitted by a CLI-spawned process. See bloodbank/docs/event-naming.md.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.cli.stderr.appended"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "cli"
    },
    "data": {
      "type": "object",
      "description": "Payload for bloodbank.v1.cli.stderr.appended.",
      "properties": {
        "session_id": {
          "type": "string",
          "minLength": 1
        },
        "process_id": {
          "type": "string",
          "minLength": 1
        },
        "chunk": {
          "type": "string"
        },
        "byte_offset": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "session_id",
        "process_id",
        "chunk"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "type",
    "kind",
    "domain",
    "data"
  ]
}
