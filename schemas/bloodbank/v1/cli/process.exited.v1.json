{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/cli/process.exited.v1.json",
  "title": "Cli Process Exited Event",
  "description": "A CLI-spawned process terminated. See bloodbank/docs/event-naming.md.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.cli.process.exited"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "cli"
    },
    "data": {
      "type": "object",
      "description": "Payload for bloodbank.v1.cli.process.exited.",
      "properties": {
        "session_id": {
          "type": "string",
          "minLength": 1
        },
        "process_id": {
          "type": "string",
          "minLength": 1
        },
        "exit_code": {
          "type": "integer"
        }
      },
      "required": [
        "session_id",
        "process_id",
        "exit_code"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "type",
    "kind",
    "domain",
    "data"
  ]
}
