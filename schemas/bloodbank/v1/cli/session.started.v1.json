{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/cli/session.started.v1.json",
  "title": "Cli Session Started Event",
  "description": "A CLI session began (e.g. claude or copilot process tree start). See bloodbank/docs/event-naming.md.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.cli.session.started"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "cli"
    },
    "data": {
      "type": "object",
      "description": "Payload for bloodbank.v1.cli.session.started.",
      "properties": {
        "session_id": {
          "type": "string",
          "minLength": 1
        },
        "working_directory": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "session_id"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "type",
    "kind",
    "domain",
    "data"
  ]
}
