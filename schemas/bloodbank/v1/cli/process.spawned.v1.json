{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/cli/process.spawned.v1.json",
  "title": "Cli Process Spawned Event",
  "description": "An OS process was spawned within a CLI session. See bloodbank/docs/event-naming.md.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.cli.process.spawned"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "cli"
    },
    "data": {
      "type": "object",
      "description": "Payload for bloodbank.v1.cli.process.spawned.",
      "properties": {
        "session_id": {
          "type": "string",
          "minLength": 1
        },
        "process_id": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": [
            "array",
            "string",
            "null"
          ],
          "description": "Argv of the spawned process."
        }
      },
      "required": [
        "session_id",
        "process_id"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "type",
    "kind",
    "domain",
    "data"
  ]
}
