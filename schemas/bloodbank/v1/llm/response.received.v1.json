{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/llm/response.received.v1.json",
  "title": "Llm Response Received Event",
  "description": "A response was received from an LLM provider. Protocol boundary. See bloodbank/docs/event-naming.md.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.llm.response.received"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "llm"
    },
    "data": {
      "type": "object",
      "description": "Payload for bloodbank.v1.llm.response.received.",
      "properties": {
        "invocation_id": {
          "type": "string",
          "minLength": 1
        },
        "response_id": {
          "type": "string",
          "minLength": 1
        },
        "request_id": {
          "type": [
            "string",
            "null"
          ],
          "description": "Pairing key for the originating request."
        }
      },
      "required": [
        "invocation_id",
        "response_id"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "type",
    "kind",
    "domain",
    "data"
  ]
}
