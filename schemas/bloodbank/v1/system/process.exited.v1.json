{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/system/process.exited.v1.json",
  "title": "System Process Exited Event",
  "description": "A host-observed process or container terminated. Used by operator monitors such as docker-health-monitor to surface exit incidents into Bloodbank. See bloodbank/docs/event-naming.md.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.system.process.exited"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "system"
    },
    "data": {
      "type": "object",
      "description": "Payload for bloodbank.v1.system.process.exited.",
      "properties": {
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "runtime": {
          "type": "string",
          "minLength": 1
        },
        "resource_kind": {
          "type": "string",
          "minLength": 1
        },
        "container_name": {
          "type": ["string", "null"]
        },
        "container_id": {
          "type": ["string", "null"]
        },
        "image": {
          "type": ["string", "null"]
        },
        "compose_project": {
          "type": ["string", "null"]
        },
        "compose_service": {
          "type": ["string", "null"]
        },
        "compose_file": {
          "type": ["string", "null"]
        },
        "working_dir": {
          "type": ["string", "null"]
        },
        "status": {
          "type": ["string", "null"]
        },
        "exit_code": {
          "type": ["integer", "null"]
        },
        "restart_policy": {
          "type": ["string", "null"]
        },
        "finished_at": {
          "type": ["string", "null"]
        },
        "started_at": {
          "type": ["string", "null"]
        },
        "observed_at": {
          "type": ["string", "null"]
        },
        "incident_summary": {
          "type": ["string", "null"]
        },
        "expected_exit": {
          "type": "boolean"
        },
        "recovery_expected": {
          "type": "boolean"
        },
        "fingerprint": {
          "type": ["string", "null"]
        }
      },
      "required": [
        "source_id",
        "runtime",
        "resource_kind",
        "incident_summary",
        "expected_exit",
        "recovery_expected"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "type",
    "kind",
    "domain",
    "data"
  ]
}
