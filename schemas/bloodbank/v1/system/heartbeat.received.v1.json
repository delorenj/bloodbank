{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/system/heartbeat.received.v1.json",
  "title": "System Heartbeat Received Event",
  "description": "A liveness heartbeat was received from a producer. Also used as the canonical smoketest fixture. See bloodbank/docs/event-naming.md.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.system.heartbeat.received"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "system"
    },
    "data": {
      "type": "object",
      "description": "Payload for bloodbank.v1.system.heartbeat.received.",
      "properties": {
        "source_id": {
          "type": "string",
          "minLength": 1,
          "description": "Identifier of the heartbeat producer (e.g. heartbeat-tick, smoketest)."
        },
        "sequence": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Monotonic counter from the producer."
        }
      },
      "required": [
        "source_id"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "type",
    "kind",
    "domain",
    "data"
  ]
}
