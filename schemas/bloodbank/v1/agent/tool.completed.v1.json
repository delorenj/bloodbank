{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/agent/tool.completed.v1.json",
  "title": "Agent Tool Completed Event",
  "description": "A tool call reached a terminal state. See bloodbank/docs/event-naming.md.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.agent.tool.completed"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "agent"
    },
    "data": {
      "type": "object",
      "description": "Payload for bloodbank.v1.agent.tool.completed.",
      "properties": {
        "invocation_id": {
          "type": "string",
          "minLength": 1
        },
        "tool_call_id": {
          "type": "string",
          "minLength": 1
        },
        "tool_name": {
          "type": "string",
          "minLength": 1
        },
        "outcome": {
          "type": "string",
          "enum": [
            "success",
            "error"
          ]
        },
        "result": {
          "description": "Tool result (open shape)."
        }
      },
      "required": [
        "invocation_id",
        "tool_call_id",
        "tool_name",
        "outcome"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "type",
    "kind",
    "domain",
    "data"
  ]
}
