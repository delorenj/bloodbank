{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/agent/invocation.started.v1.json",
  "title": "Agent Invocation Started Event",
  "description": "An agent invocation began. One round of agent runtime calling an LLM. See bloodbank/docs/event-naming.md.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.agent.invocation.started"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "agent"
    },
    "data": {
      "type": "object",
      "description": "Payload for bloodbank.v1.agent.invocation.started.",
      "properties": {
        "invocation_id": {
          "type": "string",
          "minLength": 1
        },
        "thread_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "turn_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "parent_invocation_id": {
          "type": [
            "string",
            "null"
          ],
          "description": "Set on nested invocations (sub-agents)."
        }
      },
      "required": [
        "invocation_id"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "type",
    "kind",
    "domain",
    "data"
  ]
}
