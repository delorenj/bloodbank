{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/agent/tool.requested.v1.json",
  "title": "Agent Tool Requested Event",
  "description": "An agent requested a tool call. The runtime has not executed it yet. See bloodbank/docs/event-naming.md.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.agent.tool.requested"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "agent"
    },
    "data": {
      "type": "object",
      "description": "Payload for bloodbank.v1.agent.tool.requested.",
      "properties": {
        "invocation_id": {
          "type": "string",
          "minLength": 1
        },
        "tool_call_id": {
          "type": "string",
          "minLength": 1
        },
        "tool_name": {
          "type": "string",
          "minLength": 1
        },
        "arguments": {
          "type": [
            "object",
            "null"
          ]
        }
      },
      "required": [
        "invocation_id",
        "tool_call_id",
        "tool_name"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "type",
    "kind",
    "domain",
    "data"
  ]
}
