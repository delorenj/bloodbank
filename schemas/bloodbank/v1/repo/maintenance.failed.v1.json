{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/repo/maintenance.failed.v1.json",
  "title": "Repo Maintenance Failed Event",
  "description": "A repository maintenance run failed provider evaluation, setup, or a live merge attempt.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.repo.maintenance.failed"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "repo"
    },
    "subject": {
      "const": "bloodbank.evt.v1.repo.maintenance.failed"
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "dataschema": {
      "const": "apicurio://holyfields/bloodbank.v1.repo.maintenance.failed/versions/1"
    },
    "schemaref": {
      "const": "bloodbank.v1.repo.maintenance.failed.v1"
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": 1
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tick": {
          "type": "integer",
          "minimum": 1
        },
        "at": {
          "$ref": "../../../_common/types.v1.json#/$defs/timestamp"
        },
        "automerge": {
          "type": "boolean"
        },
        "outcome": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "status": {
              "const": "failed"
            },
            "success": {
              "const": false
            },
            "provider": {
              "type": "string",
              "minLength": 1
            },
            "provider_returncode": {
              "type": "integer"
            },
            "provider_status": {
              "enum": [
                "complete",
                "changed",
                "noop",
                "no_work",
                "blocked",
                "failed"
              ]
            },
            "merge_attempts": {
              "type": "integer",
              "minimum": 0
            },
            "merge_failures": {
              "type": "integer",
              "minimum": 0
            }
          },
          "required": [
            "status",
            "success",
            "provider",
            "provider_returncode",
            "provider_status",
            "merge_attempts",
            "merge_failures"
          ]
        }
      },
      "required": [
        "schema_version",
        "run_id",
        "repository",
        "tick",
        "at",
        "automerge",
        "outcome"
      ]
    }
  },
  "required": [
    "specversion",
    "id",
    "source",
    "type",
    "subject",
    "time",
    "datacontenttype",
    "dataschema",
    "correlationid",
    "causationid",
    "producer",
    "service",
    "kind",
    "domain",
    "schemaref",
    "actor",
    "ordering_key",
    "data"
  ]
}
