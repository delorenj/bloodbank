{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/repo/task.recorded.v1.json",
  "title": "Repo Task Recorded Event",
  "description": "A PM/worker recorded a task (ticket) state update under the repo domain.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.repo.task.recorded"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "repo"
    },
    "data": {
      "type": "object",
      "description": "Payload for bloodbank.v1.repo.task.recorded.",
      "properties": {
        "repo": {
          "type": "string",
          "minLength": 1,
          "pattern": "^\\S+$"
        },
        "task_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^\\S+$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "change_kind": {
          "type": "string",
          "description": "Type of update being recorded (status, assignee, priority, estimate, metadata, etc.)."
        },
        "from": {
          "description": "Optional previous value/state.",
          "type": ["string", "number", "boolean", "object", "array", "null"]
        },
        "to": {
          "description": "Optional new value/state.",
          "type": ["string", "number", "boolean", "object", "array", "null"]
        },
        "updated_by": {
          "type": "string"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        },
        "note": {
          "type": "string"
        }
      },
      "required": [
        "repo",
        "task_id",
        "title"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "type",
    "kind",
    "domain",
    "data"
  ]
}
