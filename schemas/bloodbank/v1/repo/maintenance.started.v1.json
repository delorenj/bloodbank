{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/repo/maintenance.started.v1.json",
  "title": "Repo Maintenance Started Event",
  "description": "A repository maintenance run started. The repository identity and run controls live in data so the type remains provider-neutral.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.repo.maintenance.started"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "repo"
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": 1
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tick": {
          "type": "integer",
          "minimum": 1
        },
        "at": {
          "$ref": "../../../_common/types.v1.json#/$defs/timestamp"
        },
        "automerge": {
          "type": "boolean"
        },
        "outcome": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "status": {
              "const": "started"
            },
            "success": {
              "type": "null"
            }
          },
          "required": [
            "status",
            "success"
          ]
        }
      },
      "required": [
        "schema_version",
        "run_id",
        "repository",
        "tick",
        "at",
        "automerge",
        "outcome"
      ]
    }
  },
  "required": [
    "type",
    "kind",
    "domain",
    "data"
  ]
}
