{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/repo/decision.recorded.v1.json",
  "title": "Repo Decision Recorded Event",
  "description": "A PM agent recorded a repo-scoped decision. The repo slug belongs in data.repo, not in the CloudEvents type.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.repo.decision.recorded"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "repo"
    },
    "data": {
      "type": "object",
      "description": "Payload for bloodbank.v1.repo.decision.recorded.",
      "properties": {
        "repo": {
          "type": "string",
          "minLength": 1
        },
        "decision": {
          "type": "string",
          "minLength": 1
        },
        "basis": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "artifacts_root": {
          "type": "string"
        }
      },
      "required": [
        "repo",
        "decision"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "type",
    "kind",
    "domain",
    "data"
  ]
}
