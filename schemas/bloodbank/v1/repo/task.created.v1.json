{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/repo/task.created.v1.json",
  "title": "Repo Task Created Event",
  "description": "A PM agent created a repo-scoped task. The repo slug belongs in data.repo, not in the CloudEvents type.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.repo.task.created"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "repo"
    },
    "data": {
      "type": "object",
      "description": "Payload for bloodbank.v1.repo.task.created.",
      "properties": {
        "repo": {
          "type": "string",
          "minLength": 1
        },
        "task_id": {
          "type": "string"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "assignee": {
          "type": "string"
        }
      },
      "required": [
        "repo",
        "title"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "type",
    "kind",
    "domain",
    "data"
  ]
}
