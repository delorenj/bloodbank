{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/repo/task.completed.v1.json",
  "title": "Repo Task Completed Event",
  "description": "A PM/worker completed a repo-scoped task (ticket). The repo slug belongs in data.repo, not in the CloudEvents type.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.repo.task.completed"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "repo"
    },
    "data": {
      "type": "object",
      "description": "Payload for bloodbank.v1.repo.task.completed.",
      "properties": {
        "repo": {
          "type": "string",
          "minLength": 1,
          "pattern": "^\\S+$"
        },
        "task_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^\\S+$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["completed", "done", "closed"]
        },
        "completed_by": {
          "type": "string"
        },
        "completed_at": {
          "type": "string",
          "format": "date-time"
        },
        "resolution": {
          "type": "string"
        }
      },
      "required": [
        "repo",
        "task_id",
        "title"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "type",
    "kind",
    "domain",
    "data"
  ]
}
