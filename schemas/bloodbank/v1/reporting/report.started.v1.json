{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/reporting/report.started.v1.json",
  "title": "Reporting Report Started Event",
  "description": "A daily company report run started with an explicit reporting window and expected section set.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.reporting.report.started"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "reporting"
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": 1
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "report_date": {
          "type": "string",
          "format": "date"
        },
        "started_at": {
          "$ref": "../../../_common/types.v1.json#/$defs/timestamp"
        },
        "timezone": {
          "type": "string",
          "minLength": 1
        },
        "trigger": {
          "enum": [
            "scheduled",
            "manual",
            "retry"
          ]
        },
        "expected_sections": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "required": [
        "schema_version",
        "run_id",
        "report_date",
        "started_at",
        "timezone",
        "trigger",
        "expected_sections"
      ]
    }
  },
  "required": [
    "type",
    "kind",
    "domain",
    "data"
  ]
}
