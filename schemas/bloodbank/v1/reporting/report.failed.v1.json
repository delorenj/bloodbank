{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/reporting/report.failed.v1.json",
  "title": "Reporting Report Failed Event",
  "description": "A daily company report run failed before successful archive and delivery completion.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.reporting.report.failed"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "reporting"
    },
    "subject": {
      "const": "bloodbank.evt.v1.reporting.report.failed"
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "dataschema": {
      "const": "apicurio://holyfields/bloodbank.v1.reporting.report.failed/versions/1"
    },
    "schemaref": {
      "const": "bloodbank.v1.reporting.report.failed.v1"
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": 1
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "report_date": {
          "type": "string",
          "format": "date"
        },
        "started_at": {
          "$ref": "../../../_common/types.v1.json#/$defs/timestamp"
        },
        "failed_at": {
          "$ref": "../../../_common/types.v1.json#/$defs/timestamp"
        },
        "failure": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "phase": {
              "enum": [
                "investigation",
                "aggregation",
                "validation",
                "archive",
                "delivery"
              ]
            },
            "code": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_]{0,63}$"
            },
            "summary": {
              "type": "string",
              "minLength": 1,
              "maxLength": 500,
              "pattern": "^(?!.*(?:stderr|STDERR|(?:token|Token|secret|Secret|password|Password)\\s*[:=]|gh[pousr]_|github_pat_|sk-[A-Za-z0-9]|://[^\\s/@:]+:[^\\s/@]+@|/(?:home|root|etc|var|run|tmp)/)).*$",
              "description": "Bounded operator-safe summary. Producers must redact credentials, credential-bearing URLs, stderr dumps, and absolute filesystem paths before publishing."
            },
            "retryable": {
              "type": "boolean"
            },
            "redacted": {
              "const": true
            }
          },
          "required": [
            "phase",
            "code",
            "summary",
            "retryable",
            "redacted"
          ]
        },
        "delivery": {
          "type": "object",
          "oneOf": [
            {
              "additionalProperties": false,
              "properties": {
                "status": {
                  "const": "not_attempted"
                },
                "channel": {
                  "type": "null"
                },
                "destination_alias": {
                  "type": "null"
                },
                "attempts": {
                  "const": 0
                }
              },
              "required": [
                "status",
                "channel",
                "destination_alias",
                "attempts"
              ]
            },
            {
              "additionalProperties": false,
              "properties": {
                "status": {
                  "const": "failed"
                },
                "channel": {
                  "type": "string",
                  "pattern": "^[a-z][a-z0-9_-]{0,31}$"
                },
                "destination_alias": {
                  "type": "string",
                  "pattern": "^[a-z][a-z0-9_-]{0,63}$"
                },
                "attempts": {
                  "type": "integer",
                  "minimum": 1
                }
              },
              "required": [
                "status",
                "channel",
                "destination_alias",
                "attempts"
              ]
            }
          ]
        }
      },
      "required": [
        "schema_version",
        "run_id",
        "report_date",
        "started_at",
        "failed_at",
        "failure",
        "delivery"
      ]
    }
  },
  "required": [
    "specversion",
    "id",
    "source",
    "type",
    "subject",
    "time",
    "datacontenttype",
    "dataschema",
    "correlationid",
    "causationid",
    "producer",
    "service",
    "kind",
    "domain",
    "schemaref",
    "actor",
    "ordering_key",
    "data"
  ]
}
