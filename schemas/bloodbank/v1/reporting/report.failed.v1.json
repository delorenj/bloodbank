{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/reporting/report.failed.v1.json",
  "title": "Reporting Report Failed Event",
  "description": "A daily company report run failed before successful archive and delivery completion.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.reporting.report.failed"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "reporting"
    },
    "subject": {
      "const": "bloodbank.evt.v1.reporting.report.failed"
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "dataschema": {
      "const": "apicurio://holyfields/bloodbank.v1.reporting.report.failed/versions/1"
    },
    "schemaref": {
      "const": "bloodbank.v1.reporting.report.failed.v1"
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": 1
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "report_date": {
          "type": "string",
          "format": "date"
        },
        "started_at": {
          "$ref": "../../../_common/types.v1.json#/$defs/timestamp"
        },
        "failed_at": {
          "$ref": "../../../_common/types.v1.json#/$defs/timestamp"
        },
        "failure": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "phase": {
              "enum": [
                "investigation",
                "aggregation",
                "validation",
                "archive",
                "delivery"
              ]
            },
            "code": {
              "type": "string",
              "minLength": 1
            },
            "summary": {
              "type": "string",
              "minLength": 1
            },
            "retryable": {
              "type": "boolean"
            }
          },
          "required": [
            "phase",
            "code",
            "summary",
            "retryable"
          ]
        },
        "delivery": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "status": {
              "enum": [
                "not_attempted",
                "failed"
              ]
            },
            "channel": {
              "type": [
                "string",
                "null"
              ],
              "minLength": 1
            },
            "destination": {
              "type": [
                "string",
                "null"
              ],
              "minLength": 1
            },
            "attempts": {
              "type": "integer",
              "minimum": 0
            }
          },
          "required": [
            "status",
            "channel",
            "destination",
            "attempts"
          ]
        }
      },
      "required": [
        "schema_version",
        "run_id",
        "report_date",
        "started_at",
        "failed_at",
        "failure",
        "delivery"
      ]
    }
  },
  "required": [
    "specversion",
    "id",
    "source",
    "type",
    "subject",
    "time",
    "datacontenttype",
    "dataschema",
    "correlationid",
    "causationid",
    "producer",
    "service",
    "kind",
    "domain",
    "schemaref",
    "actor",
    "ordering_key",
    "data"
  ]
}
