{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/reporting/report.completed.v1.json",
  "title": "Reporting Report Completed Event",
  "description": "A daily company report was composed, archived, and reached its declared delivery outcome.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.reporting.report.completed"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "reporting"
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": 1
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "report_date": {
          "type": "string",
          "format": "date"
        },
        "started_at": {
          "$ref": "../../../_common/types.v1.json#/$defs/timestamp"
        },
        "completed_at": {
          "$ref": "../../../_common/types.v1.json#/$defs/timestamp"
        },
        "outcome": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "status": {
              "enum": [
                "complete",
                "partial"
              ]
            },
            "sections_expected": {
              "type": "integer",
              "minimum": 1
            },
            "sections_complete": {
              "type": "integer",
              "minimum": 0
            },
            "sections_degraded": {
              "type": "integer",
              "minimum": 0
            }
          },
          "required": [
            "status",
            "sections_expected",
            "sections_complete",
            "sections_degraded"
          ]
        },
        "artifacts": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "report_json_path": {
              "type": "string",
              "minLength": 1
            },
            "markdown_path": {
              "type": "string",
              "minLength": 1
            },
            "commit_marker_path": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "report_json_path",
            "markdown_path",
            "commit_marker_path"
          ]
        },
        "delivery": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "status": {
              "enum": [
                "delivered",
                "skipped"
              ]
            },
            "channel": {
              "type": "string",
              "minLength": 1
            },
            "destination": {
              "type": "string",
              "minLength": 1
            },
            "attempts": {
              "type": "integer",
              "minimum": 0
            },
            "delivered_at": {
              "oneOf": [
                {
                  "$ref": "../../../_common/types.v1.json#/$defs/timestamp"
                },
                {
                  "type": "null"
                }
              ]
            }
          },
          "required": [
            "status",
            "channel",
            "destination",
            "attempts",
            "delivered_at"
          ]
        }
      },
      "required": [
        "schema_version",
        "run_id",
        "report_date",
        "started_at",
        "completed_at",
        "outcome",
        "artifacts",
        "delivery"
      ]
    }
  },
  "required": [
    "type",
    "kind",
    "domain",
    "data"
  ]
}
