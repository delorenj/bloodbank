{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/reporting/report.completed.v1.json",
  "title": "Reporting Report Completed Event",
  "description": "A daily company report was composed, archived, and reached its declared delivery outcome.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.reporting.report.completed"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "reporting"
    },
    "subject": {
      "const": "bloodbank.evt.v1.reporting.report.completed"
    },
    "datacontenttype": {
      "const": "application/json"
    },
    "dataschema": {
      "const": "apicurio://holyfields/bloodbank.v1.reporting.report.completed/versions/1"
    },
    "schemaref": {
      "const": "bloodbank.v1.reporting.report.completed.v1"
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "schema_version": {
          "const": 1
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "report_date": {
          "type": "string",
          "format": "date"
        },
        "started_at": {
          "$ref": "../../../_common/types.v1.json#/$defs/timestamp"
        },
        "completed_at": {
          "$ref": "../../../_common/types.v1.json#/$defs/timestamp"
        },
        "outcome": {
          "type": "object",
          "oneOf": [
            {
              "additionalProperties": false,
              "properties": {
                "status": {
                  "const": "complete"
                },
                "sections": {
                  "type": "object",
                  "minProperties": 1,
                  "propertyNames": {
                    "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
                  },
                  "additionalProperties": {
                    "const": "complete"
                  }
                }
              },
              "required": [
                "status",
                "sections"
              ]
            },
            {
              "additionalProperties": false,
              "properties": {
                "status": {
                  "const": "partial"
                },
                "sections": {
                  "type": "object",
                  "minProperties": 1,
                  "propertyNames": {
                    "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
                  },
                  "additionalProperties": {
                    "enum": [
                      "complete",
                      "degraded"
                    ]
                  },
                  "not": {
                    "additionalProperties": {
                      "const": "complete"
                    }
                  }
                }
              },
              "required": [
                "status",
                "sections"
              ]
            }
          ]
        },
        "artifacts": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "report_artifact_id": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            },
            "markdown_artifact_id": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            },
            "commit_marker_id": {
              "type": "string",
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
            }
          },
          "required": [
            "report_artifact_id",
            "markdown_artifact_id",
            "commit_marker_id"
          ]
        },
        "delivery": {
          "type": "object",
          "oneOf": [
            {
              "additionalProperties": false,
              "properties": {
                "status": {
                  "const": "delivered"
                },
                "channel": {
                  "type": "string",
                  "pattern": "^[a-z][a-z0-9_-]{0,31}$"
                },
                "destination_alias": {
                  "type": "string",
                  "pattern": "^[a-z][a-z0-9_-]{0,63}$"
                },
                "attempts": {
                  "type": "integer",
                  "minimum": 1
                },
                "delivered_at": {
                  "$ref": "../../../_common/types.v1.json#/$defs/timestamp"
                }
              },
              "required": [
                "status",
                "channel",
                "destination_alias",
                "attempts",
                "delivered_at"
              ]
            },
            {
              "additionalProperties": false,
              "properties": {
                "status": {
                  "const": "skipped"
                },
                "channel": {
                  "type": "string",
                  "pattern": "^[a-z][a-z0-9_-]{0,31}$"
                },
                "destination_alias": {
                  "type": "string",
                  "pattern": "^[a-z][a-z0-9_-]{0,63}$"
                },
                "attempts": {
                  "const": 0
                },
                "delivered_at": {
                  "type": "null"
                },
                "reason": {
                  "type": "string",
                  "pattern": "^[a-z][a-z0-9_]{0,63}$"
                }
              },
              "required": [
                "status",
                "channel",
                "destination_alias",
                "attempts",
                "delivered_at",
                "reason"
              ]
            }
          ]
        }
      },
      "required": [
        "schema_version",
        "run_id",
        "report_date",
        "started_at",
        "completed_at",
        "outcome",
        "artifacts",
        "delivery"
      ]
    }
  },
  "required": [
    "specversion",
    "id",
    "source",
    "type",
    "subject",
    "time",
    "datacontenttype",
    "dataschema",
    "correlationid",
    "causationid",
    "producer",
    "service",
    "kind",
    "domain",
    "schemaref",
    "actor",
    "ordering_key",
    "data"
  ]
}
