{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/lifecycle/blocker.resolved.v1.json",
  "title": "Authoritative Lifecycle Blocker Resolved Event",
  "description": "A previously active blocker was resolved in a versioned lifecycle state. Rejection or command reply outcomes never use this event unless authority state actually changed.",
  "type": "object",
  "allOf": [
    { "$ref": "../../../_common/cloudevent_base.v1.json" }
  ],
  "properties": {
    "type": { "const": "bloodbank.v1.lifecycle.blocker.resolved" },
    "kind": { "const": "event" },
    "domain": { "const": "lifecycle" },
    "subject": { "const": "bloodbank.evt.v1.lifecycle.blocker.resolved" },
    "datacontenttype": { "const": "application/json" },
    "dataschema": {
      "const": "apicurio://holyfields/bloodbank.v1.lifecycle.blocker.resolved/versions/1"
    },
    "schemaref": { "const": "bloodbank.v1.lifecycle.blocker.resolved.v1" },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "contract_version": { "const": 1 },
        "lifecycle_id": { "type": "string", "minLength": 1 },
        "repo": { "type": "string", "minLength": 1 },
        "spec_version": { "type": "integer", "minimum": 1 },
        "state_version": { "type": "integer", "minimum": 1 },
        "previous_state_version": { "type": "integer", "minimum": 1 },
        "blocker": {
          "$ref": "../../../_common/lifecycle_contracts.v1.json#/$defs/blocker"
        },
        "resolution": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "resolved_at": { "$ref": "../../../_common/types.v1.json#/$defs/timestamp" },
            "resolved_by": { "type": "string", "minLength": 1 },
            "reason_code": { "type": "string", "minLength": 1 }
          },
          "required": ["resolved_at", "resolved_by", "reason_code"]
        },
        "remaining_blocking_blockers": { "type": "integer", "minimum": 0 },
        "provenance": {
          "$ref": "../../../_common/lifecycle_contracts.v1.json#/$defs/provenance"
        },
        "freshness": {
          "$ref": "../../../_common/lifecycle_contracts.v1.json#/$defs/freshness"
        },
        "publication": {
          "$ref": "../../../_common/lifecycle_contracts.v1.json#/$defs/publication"
        }
      },
      "required": [
        "contract_version",
        "lifecycle_id",
        "repo",
        "spec_version",
        "state_version",
        "previous_state_version",
        "blocker",
        "resolution",
        "remaining_blocking_blockers",
        "provenance",
        "freshness",
        "publication"
      ]
    }
  },
  "required": [
    "specversion",
    "id",
    "source",
    "type",
    "subject",
    "time",
    "datacontenttype",
    "dataschema",
    "correlationid",
    "causationid",
    "producer",
    "service",
    "kind",
    "domain",
    "schemaref",
    "actor",
    "ordering_key",
    "data"
  ]
}
