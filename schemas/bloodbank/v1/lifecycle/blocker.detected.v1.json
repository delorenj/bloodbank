{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/lifecycle/blocker.detected.v1.json",
  "title": "Authoritative Lifecycle Blocker Detected Event",
  "description": "A blocker became active in a versioned lifecycle state. Published through the standalone authority's transactional outbox.",
  "type": "object",
  "allOf": [
    { "$ref": "../../../_common/cloudevent_base.v1.json" }
  ],
  "properties": {
    "type": { "const": "bloodbank.v1.lifecycle.blocker.detected" },
    "kind": { "const": "event" },
    "domain": { "const": "lifecycle" },
    "subject": { "const": "bloodbank.evt.v1.lifecycle.blocker.detected" },
    "datacontenttype": { "const": "application/json" },
    "dataschema": {
      "const": "apicurio://holyfields/bloodbank.v1.lifecycle.blocker.detected/versions/1"
    },
    "schemaref": { "const": "bloodbank.v1.lifecycle.blocker.detected.v1" },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "contract_version": { "const": 1 },
        "lifecycle_id": { "type": "string", "minLength": 1 },
        "repo": { "type": "string", "minLength": 1 },
        "spec_version": { "type": "integer", "minimum": 1 },
        "state_version": { "type": "integer", "minimum": 1 },
        "previous_state_version": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "blocker": {
          "$ref": "../../../_common/lifecycle_contracts.v1.json#/$defs/blocker"
        },
        "provenance": {
          "$ref": "../../../_common/lifecycle_contracts.v1.json#/$defs/provenance"
        },
        "freshness": {
          "$ref": "../../../_common/lifecycle_contracts.v1.json#/$defs/freshness"
        },
        "publication": {
          "$ref": "../../../_common/lifecycle_contracts.v1.json#/$defs/publication"
        }
      },
      "required": [
        "contract_version",
        "lifecycle_id",
        "repo",
        "spec_version",
        "state_version",
        "previous_state_version",
        "blocker",
        "provenance",
        "freshness",
        "publication"
      ]
    }
  },
  "required": [
    "specversion",
    "id",
    "source",
    "type",
    "subject",
    "time",
    "datacontenttype",
    "dataschema",
    "correlationid",
    "causationid",
    "producer",
    "service",
    "kind",
    "domain",
    "schemaref",
    "actor",
    "ordering_key",
    "data"
  ]
}
