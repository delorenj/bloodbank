{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/lifecycle/roadmap.updated.v1.json",
  "title": "Lifecycle Roadmap Updated Event",
  "description": "The definition of 'done' or the path to done changed for this lifecycle. Fires on scope changes, phase additions/removals, or acceptance criteria updates.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.lifecycle.roadmap.updated"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "lifecycle"
    },
    "data": {
      "type": "object",
      "description": "Payload for bloodbank.v1.lifecycle.lifecycle.roadmap.updated.",
      "properties": {
        "lifecycle_id": {
          "type": "string",
          "minLength": 1
        },
        "repo": {
          "type": "string",
          "minLength": 1
        },
        "roadmap": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "version": {
              "type": "integer",
              "minimum": 1
            },
            "previous_version": {
              "type": "integer",
              "minimum": 1
            },
            "phases": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "name": {
                    "type": "string"
                  },
                  "kind": {
                    "type": "string",
                    "enum": ["mvp", "phase", "milestone", "release"]
                  },
                  "entry_criteria": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "exit_criteria": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "gate_policy": {
                    "type": "object",
                    "properties": {
                      "on_reached": {
                        "type": "string"
                      },
                      "blocking": {
                        "type": "boolean"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "progress": {
          "type": "object",
          "properties": {
            "percent": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "roadmap_version": {
              "type": "integer"
            },
            "basis": {
              "type": "string",
              "description": "How progress was computed (e.g. weighted_checkpoints, ticket_count)."
            }
          }
        },
        "change_reason": {
          "type": "string",
          "description": "Why the roadmap was updated (scope_change, checkpoint_reached, replan, etc.)."
        }
      },
      "required": [
        "lifecycle_id",
        "repo",
        "roadmap"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "type",
    "kind",
    "domain",
    "data"
  ]
}
