{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/lifecycle/intent.submit.reply.v1.json",
  "title": "Lifecycle Intent Submit Reply",
  "description": "Stable verdict for lifecycle.intent.submit. Rejection verdicts are structurally unable to claim mutation; idempotent replies identify the already-applied event without claiming a new mutation.",
  "type": "object",
  "allOf": [
    { "$ref": "../../../_common/cloudevent_base.v1.json" }
  ],
  "properties": {
    "type": { "const": "bloodbank.v1.lifecycle.intent.submit" },
    "kind": { "const": "reply" },
    "domain": { "const": "lifecycle" },
    "subject": { "const": "bloodbank.rpy.v1.lifecycle.intent.submit" },
    "datacontenttype": { "const": "application/json" },
    "dataschema": {
      "const": "apicurio://holyfields/bloodbank.v1.lifecycle.intent.submit.reply/versions/1"
    },
    "schemaref": { "const": "bloodbank.v1.lifecycle.intent.submit.reply.v1" },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "contract_version": { "const": 1 },
        "lifecycle_id": { "type": "string", "minLength": 1 },
        "repo": { "type": "string", "minLength": 1 },
        "reply_to_command_event_id": {
          "$ref": "../../../_common/types.v1.json#/$defs/uuid"
        },
        "command_id": { "$ref": "../../../_common/types.v1.json#/$defs/uuid" },
        "idempotency_key": { "type": "string", "minLength": 1 },
        "expected_state_version": { "type": "integer", "minimum": 1 },
        "observed_state_version": { "type": "integer", "minimum": 1 },
        "verdict": {
          "type": "string",
          "enum": [
            "accepted",
            "applied",
            "idempotent",
            "stale",
            "unauthorized",
            "malformed",
            "illegal"
          ]
        },
        "mutated": { "type": "boolean" },
        "resulting_state_version": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "applied_event_id": {
          "oneOf": [
            { "$ref": "../../../_common/types.v1.json#/$defs/uuid" },
            { "type": "null" }
          ]
        },
        "capability_id": { "type": ["string", "null"] },
        "reason_code": { "type": "string", "minLength": 1 },
        "responded_at": {
          "$ref": "../../../_common/types.v1.json#/$defs/timestamp"
        }
      },
      "required": [
        "contract_version",
        "lifecycle_id",
        "repo",
        "reply_to_command_event_id",
        "command_id",
        "idempotency_key",
        "expected_state_version",
        "observed_state_version",
        "verdict",
        "mutated",
        "resulting_state_version",
        "applied_event_id",
        "capability_id",
        "reason_code",
        "responded_at"
      ],
      "allOf": [
        {
          "if": {
            "properties": { "verdict": { "const": "applied" } },
            "required": ["verdict"]
          },
          "then": {
            "properties": {
              "mutated": { "const": true },
              "resulting_state_version": { "type": "integer", "minimum": 1 },
              "applied_event_id": {
                "$ref": "../../../_common/types.v1.json#/$defs/uuid"
              }
            }
          }
        },
        {
          "if": {
            "properties": { "verdict": { "const": "idempotent" } },
            "required": ["verdict"]
          },
          "then": {
            "properties": {
              "mutated": { "const": false },
              "resulting_state_version": { "type": "integer", "minimum": 1 },
              "applied_event_id": {
                "$ref": "../../../_common/types.v1.json#/$defs/uuid"
              }
            }
          }
        },
        {
          "if": {
            "properties": { "verdict": { "const": "accepted" } },
            "required": ["verdict"]
          },
          "then": {
            "properties": {
              "mutated": { "const": false },
              "resulting_state_version": { "type": "null" },
              "applied_event_id": { "type": "null" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "verdict": {
                "enum": ["stale", "unauthorized", "malformed", "illegal"]
              }
            },
            "required": ["verdict"]
          },
          "then": {
            "properties": {
              "mutated": { "const": false },
              "resulting_state_version": { "type": "null" },
              "applied_event_id": { "type": "null" }
            }
          }
        }
      ]
    }
  },
  "required": [
    "specversion",
    "id",
    "source",
    "type",
    "subject",
    "time",
    "datacontenttype",
    "dataschema",
    "correlationid",
    "causationid",
    "producer",
    "service",
    "kind",
    "domain",
    "schemaref",
    "actor",
    "data"
  ]
}
