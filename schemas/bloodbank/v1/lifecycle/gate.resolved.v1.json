{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/lifecycle/gate.resolved.v1.json",
  "title": "Lifecycle Gate Resolved Event",
  "description": "A previously opened gate has been resolved. The lifecycle may now resume if no other blocking gates remain.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.lifecycle.gate.resolved"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "lifecycle"
    },
    "data": {
      "type": "object",
      "description": "Payload for bloodbank.v1.lifecycle.lifecycle.gate.resolved.",
      "properties": {
        "lifecycle_id": {
          "type": "string",
          "minLength": 1
        },
        "repo": {
          "type": "string",
          "minLength": 1
        },
        "gate": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "kind": {
              "type": "string",
              "enum": ["human_review", "ci_gate", "approval", "security_review", "custom"]
            },
            "blocking": {
              "type": "boolean"
            },
            "resolution": {
              "type": "string",
              "enum": ["approved", "rejected", "bypassed", "auto_resolved", "superseded"]
            },
            "resolved_by": {
              "type": "string"
            },
            "resolved_at": {
              "type": "string",
              "format": "date-time"
            },
            "reason": {
              "type": "string"
            }
          },
          "required": ["id", "kind", "resolution"]
        },
        "remaining_blocking_gates": {
          "type": "integer",
          "minimum": 0,
          "description": "Count of blocking gates still open after this resolution."
        }
      },
      "required": [
        "lifecycle_id",
        "repo",
        "gate"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "type",
    "kind",
    "domain",
    "data"
  ]
}
