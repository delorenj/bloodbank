{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/lifecycle/snapshot.updated.v1.json",
  "title": "Authoritative Lifecycle Snapshot Updated Event",
  "description": "A complete versioned projection source published transactionally by the standalone lifecycle authority, including state, legal frontier, obligations, blockers, gates, capabilities, evidence provenance, and freshness.",
  "type": "object",
  "allOf": [
    { "$ref": "../../../_common/cloudevent_base.v1.json" }
  ],
  "properties": {
    "type": { "const": "bloodbank.v1.lifecycle.snapshot.updated" },
    "kind": { "const": "event" },
    "domain": { "const": "lifecycle" },
    "subject": { "const": "bloodbank.evt.v1.lifecycle.snapshot.updated" },
    "datacontenttype": { "const": "application/json" },
    "dataschema": {
      "const": "apicurio://holyfields/bloodbank.v1.lifecycle.snapshot.updated/versions/1"
    },
    "schemaref": { "const": "bloodbank.v1.lifecycle.snapshot.updated.v1" },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "contract_version": { "const": 1 },
        "lifecycle_id": { "type": "string", "minLength": 1 },
        "repo": { "type": "string", "minLength": 1 },
        "spec_version": { "type": "integer", "minimum": 1 },
        "state_version": { "type": "integer", "minimum": 1 },
        "previous_state_version": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "state": {
          "$ref": "../../../_common/lifecycle_contracts.v1.json#/$defs/state_summary"
        },
        "legal_frontier": {
          "type": "array",
          "items": {
            "$ref": "../../../_common/lifecycle_contracts.v1.json#/$defs/frontier_item"
          }
        },
        "obligations": {
          "type": "array",
          "items": {
            "$ref": "../../../_common/lifecycle_contracts.v1.json#/$defs/obligation"
          }
        },
        "blockers": {
          "type": "array",
          "items": {
            "$ref": "../../../_common/lifecycle_contracts.v1.json#/$defs/blocker"
          }
        },
        "gates": {
          "type": "array",
          "items": {
            "$ref": "../../../_common/lifecycle_contracts.v1.json#/$defs/gate"
          }
        },
        "capabilities": {
          "type": "array",
          "items": {
            "$ref": "../../../_common/lifecycle_contracts.v1.json#/$defs/capability"
          }
        },
        "provenance": {
          "$ref": "../../../_common/lifecycle_contracts.v1.json#/$defs/provenance"
        },
        "freshness": {
          "$ref": "../../../_common/lifecycle_contracts.v1.json#/$defs/freshness"
        },
        "publication": {
          "$ref": "../../../_common/lifecycle_contracts.v1.json#/$defs/publication"
        }
      },
      "required": [
        "contract_version",
        "lifecycle_id",
        "repo",
        "spec_version",
        "state_version",
        "previous_state_version",
        "state",
        "legal_frontier",
        "obligations",
        "blockers",
        "gates",
        "capabilities",
        "provenance",
        "freshness",
        "publication"
      ],
      "allOf": [
        {
          "if": {
            "properties": { "state_version": { "const": 1 } },
            "required": ["state_version"]
          },
          "then": {
            "properties": { "previous_state_version": { "type": "null" } }
          },
          "else": {
            "properties": {
              "previous_state_version": { "type": "integer", "minimum": 1 }
            }
          }
        }
      ]
    }
  },
  "required": [
    "specversion",
    "id",
    "source",
    "type",
    "subject",
    "time",
    "datacontenttype",
    "dataschema",
    "correlationid",
    "causationid",
    "producer",
    "service",
    "kind",
    "domain",
    "schemaref",
    "actor",
    "ordering_key",
    "data"
  ]
}
