{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/lifecycle/mission.created.v1.json",
  "title": "Lifecycle Created Event",
  "description": "A new lifecycle was created. A lifecycle is the finite, observable execution envelope for a development mission.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.lifecycle.mission.created"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "lifecycle"
    },
    "data": {
      "type": "object",
      "description": "Payload for bloodbank.v1.lifecycle.lifecycle.created.",
      "properties": {
        "lifecycle_id": {
          "type": "string",
          "minLength": 1,
          "description": "Stable unique identifier for this lifecycle."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable name for this lifecycle."
        },
        "repo": {
          "type": "string",
          "minLength": 1,
          "description": "Primary repo slug this lifecycle is tied to."
        },
        "repos": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "Optional: multiple repos this lifecycle spans."
        },
        "roadmap_id": {
          "type": "string",
          "description": "Initial roadmap this lifecycle points at."
        },
        "status": {
          "type": "string",
          "enum": ["planned", "active", "waiting", "blocked", "paused", "disabled", "completed", "canceled", "archived"],
          "description": "Initial status of the lifecycle."
        },
        "health": {
          "type": "string",
          "enum": ["nominal", "at_risk", "stalled", "degraded", "blocked"],
          "description": "Initial health of the lifecycle."
        },
        "created_by": {
          "type": "string",
          "description": "Agent or operator that created this lifecycle."
        }
      },
      "required": [
        "lifecycle_id",
        "name",
        "repo",
        "status",
        "health"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "type",
    "kind",
    "domain",
    "data"
  ]
}
