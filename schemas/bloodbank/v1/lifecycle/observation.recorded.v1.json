{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/lifecycle/observation.recorded.v1.json",
  "title": "Lifecycle Observation Recorded Event",
  "description": "A lossless observation made available to the standalone lifecycle authority. The adapter preserves source CloudEvent identity, provenance, source time, payload, and payload hash; it does not derive lifecycle truth.",
  "type": "object",
  "allOf": [
    { "$ref": "../../../_common/cloudevent_base.v1.json" }
  ],
  "properties": {
    "type": { "const": "bloodbank.v1.lifecycle.observation.recorded" },
    "kind": { "const": "event" },
    "domain": { "const": "lifecycle" },
    "subject": { "const": "bloodbank.evt.v1.lifecycle.observation.recorded" },
    "datacontenttype": { "const": "application/json" },
    "dataschema": {
      "const": "apicurio://holyfields/bloodbank.v1.lifecycle.observation.recorded/versions/1"
    },
    "schemaref": { "const": "bloodbank.v1.lifecycle.observation.recorded.v1" },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "contract_version": { "const": 1 },
        "observation_id": { "$ref": "../../../_common/types.v1.json#/$defs/uuid" },
        "lifecycle_id": { "type": "string", "minLength": 1 },
        "repo": { "type": "string", "minLength": 1 },
        "observation_kind": {
          "type": "string",
          "enum": ["repo_task_event", "repository_event", "ci_event", "agent_event", "external_event"]
        },
        "source_event": {
          "$ref": "../../../_common/lifecycle_contracts.v1.json#/$defs/source_event"
        },
        "payload_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "payload": {
          "type": "object",
          "description": "Source data preserved without lifecycle interpretation."
        }
      },
      "required": [
        "contract_version",
        "observation_id",
        "lifecycle_id",
        "repo",
        "observation_kind",
        "source_event",
        "payload_sha256",
        "payload"
      ]
    }
  },
  "required": [
    "specversion",
    "id",
    "source",
    "type",
    "subject",
    "time",
    "datacontenttype",
    "dataschema",
    "correlationid",
    "causationid",
    "producer",
    "service",
    "kind",
    "domain",
    "schemaref",
    "actor",
    "ordering_key",
    "data"
  ]
}
