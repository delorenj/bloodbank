{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/lifecycle/gate.opened.v1.json",
  "title": "Lifecycle Gate Opened Event",
  "description": "A gate has opened on this lifecycle. Gates are intentional pauses or review points. A blocking gate halts progress; a non-blocking gate allows parallel work to continue.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.lifecycle.gate.opened"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "lifecycle"
    },
    "data": {
      "type": "object",
      "description": "Payload for bloodbank.v1.lifecycle.lifecycle.gate.opened.",
      "properties": {
        "lifecycle_id": {
          "type": "string",
          "minLength": 1
        },
        "repo": {
          "type": "string",
          "minLength": 1
        },
        "gate": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "kind": {
              "type": "string",
              "enum": ["human_review", "ci_gate", "approval", "security_review", "custom"]
            },
            "blocking": {
              "type": "boolean",
              "description": "If true, progress is halted until resolved."
            },
            "reason": {
              "type": "string",
              "description": "Human-readable reason the gate was opened."
            },
            "continue_policy": {
              "type": "string",
              "enum": ["hold_until_resolved", "continue_parallel_work", "auto_resolve_after_sla"],
              "description": "Policy for how the lifecycle proceeds while this gate is open."
            },
            "owner_kind": {
              "type": "string",
              "enum": ["human", "agent", "system", "service"]
            },
            "owner_id": {
              "type": "string"
            },
            "sla_due_at": {
              "type": "string",
              "format": "date-time",
              "description": "Optional SLA deadline for resolving this gate."
            },
            "triggered_by_checkpoint_id": {
              "type": "string",
              "description": "If this gate was opened because a checkpoint was reached."
            }
          },
          "required": ["id", "kind", "blocking"]
        }
      },
      "required": [
        "lifecycle_id",
        "repo",
        "gate"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "type",
    "kind",
    "domain",
    "data"
  ]
}
