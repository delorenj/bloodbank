{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/lifecycle/intent.submit.command.v1.json",
  "title": "Lifecycle Intent Submit Command",
  "description": "A capability-scoped request to the standalone lifecycle authority. expected_state_version provides optimistic concurrency; command_id and idempotency_key remain stable across retries.",
  "type": "object",
  "allOf": [
    { "$ref": "../../../_common/cloudevent_base.v1.json" }
  ],
  "properties": {
    "type": { "const": "bloodbank.v1.lifecycle.intent.submit" },
    "kind": { "const": "command" },
    "domain": { "const": "lifecycle" },
    "subject": { "const": "bloodbank.cmd.v1.lifecycle.intent.submit" },
    "datacontenttype": { "const": "application/json" },
    "dataschema": {
      "const": "apicurio://holyfields/bloodbank.v1.lifecycle.intent.submit.command/versions/1"
    },
    "schemaref": {
      "const": "bloodbank.v1.lifecycle.intent.submit.command.v1"
    },
    "delivery": { "const": "single_consumer" },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "contract_version": { "const": 1 },
        "lifecycle_id": { "type": "string", "minLength": 1 },
        "repo": { "type": "string", "minLength": 1 },
        "expected_state_version": { "type": "integer", "minimum": 1 },
        "intent": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "target": { "type": "string", "minLength": 1 },
            "parameters": { "type": "object" }
          },
          "required": ["name", "target", "parameters"]
        },
        "capability": {
          "$ref": "../../../_common/lifecycle_contracts.v1.json#/$defs/capability_context"
        },
        "requested_at": {
          "$ref": "../../../_common/types.v1.json#/$defs/timestamp"
        }
      },
      "required": [
        "contract_version",
        "lifecycle_id",
        "repo",
        "expected_state_version",
        "intent",
        "capability",
        "requested_at"
      ]
    }
  },
  "required": [
    "specversion",
    "id",
    "source",
    "type",
    "subject",
    "time",
    "datacontenttype",
    "dataschema",
    "correlationid",
    "causationid",
    "producer",
    "service",
    "kind",
    "domain",
    "schemaref",
    "actor",
    "command_id",
    "idempotency_key",
    "delivery",
    "data"
  ]
}
