{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/lifecycle/checkpoint.reached.v1.json",
  "title": "Lifecycle Checkpoint Reached Event",
  "description": "The system has evidence that a checkpoint is satisfied. Checkpoints are versioned roadmap milestones. Consumers subscribe to checkpoint.kind == 'mvp' for MVP events.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.lifecycle.checkpoint.reached"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "lifecycle"
    },
    "data": {
      "type": "object",
      "description": "Payload for bloodbank.v1.lifecycle.lifecycle.checkpoint.reached.",
      "properties": {
        "lifecycle_id": {
          "type": "string",
          "minLength": 1
        },
        "repo": {
          "type": "string",
          "minLength": 1
        },
        "checkpoint": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "kind": {
              "type": "string",
              "enum": ["mvp", "phase", "milestone", "release", "custom"]
            },
            "name": {
              "type": "string"
            },
            "roadmap_version": {
              "type": "integer",
              "minimum": 1
            },
            "phase_id": {
              "type": "string",
              "description": "The phase this checkpoint belongs to."
            },
            "evidence": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "kind": {
                    "type": "string"
                  },
                  "url": {
                    "type": "string"
                  },
                  "summary": {
                    "type": "string"
                  }
                }
              },
              "description": "Artifacts or signals that satisfied this checkpoint."
            }
          },
          "required": ["id", "kind", "name", "roadmap_version"]
        },
        "progress": {
          "type": "object",
          "properties": {
            "percent": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "roadmap_version": {
              "type": "integer"
            }
          }
        }
      },
      "required": [
        "lifecycle_id",
        "repo",
        "checkpoint"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "type",
    "kind",
    "domain",
    "data"
  ]
}
