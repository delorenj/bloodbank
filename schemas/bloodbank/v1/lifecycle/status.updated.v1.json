{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/lifecycle/status.updated.v1.json",
  "title": "Lifecycle Status Updated Event",
  "description": "The aggregate lifecycle status changed. This is the primary event for detecting blocked pipelines, stalls, and state transitions. Consumers filter on data.current.status and data.previous.status.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.lifecycle.status.updated"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "lifecycle"
    },
    "data": {
      "type": "object",
      "description": "Payload for bloodbank.v1.lifecycle.lifecycle.status.updated.",
      "properties": {
        "lifecycle_id": {
          "type": "string",
          "minLength": 1
        },
        "schema_version": {
          "type": "string",
          "description": "Schema version of this payload shape."
        },
        "repo": {
          "type": "string",
          "minLength": 1
        },
        "previous": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": ["planned", "active", "waiting", "blocked", "paused", "disabled", "completed", "canceled", "archived"]
            },
            "health": {
              "type": "string",
              "enum": ["nominal", "at_risk", "stalled", "degraded", "blocked"]
            },
            "phase": {
              "type": "string",
              "description": "Current roadmap phase at time of previous state."
            },
            "progress_percent": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            }
          },
          "required": ["status", "health"]
        },
        "current": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": ["planned", "active", "waiting", "blocked", "paused", "disabled", "completed", "canceled", "archived"]
            },
            "health": {
              "type": "string",
              "enum": ["nominal", "at_risk", "stalled", "degraded", "blocked"]
            },
            "phase": {
              "type": "string"
            },
            "progress_percent": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            }
          },
          "required": ["status", "health"]
        },
        "transition": {
          "type": "object",
          "description": "Metadata about how and why this transition occurred.",
          "properties": {
            "reason": {
              "type": "string",
              "description": "Machine-readable reason code (e.g. NO_RUNNABLE_WORK, PROGRESS_DETECTED, GATE_RESOLVED)."
            },
            "computed": {
              "type": "boolean",
              "description": "True if this transition was auto-computed by the lifecycle evaluator."
            },
            "detector": {
              "type": "string",
              "description": "Name/version of the detector that computed this transition."
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Confidence score for computed transitions."
            }
          }
        },
        "blockers": {
          "type": "array",
          "description": "Active blockers when status is blocked or waiting.",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "kind": {
                "type": "string",
                "enum": [
                  "missing_human_input",
                  "human_review_required",
                  "dependency_not_ready",
                  "dependency_failed",
                  "ci_failing",
                  "tests_failing",
                  "merge_conflict",
                  "agent_run_failed",
                  "agent_idle",
                  "scheduler_down",
                  "auth_required",
                  "credential_missing",
                  "environment_unavailable",
                  "rate_limited",
                  "scope_ambiguous",
                  "acceptance_criteria_missing",
                  "planning_gap",
                  "ticket_state_inconsistent",
                  "repository_locked",
                  "repository_dirty"
                ]
              },
              "scope": {
                "type": "string",
                "enum": ["lifecycle", "ticket", "repo", "agent", "system"]
              },
              "blocking": {
                "type": "boolean"
              },
              "summary": {
                "type": "string"
              },
              "owner_kind": {
                "type": "string",
                "enum": ["human", "agent", "system", "service"]
              },
              "owner_id": {
                "type": "string"
              },
              "created_at": {
                "type": "string",
                "format": "date-time"
              }
            },
            "required": ["id", "kind", "blocking"]
          }
        },
        "signals": {
          "type": "object",
          "description": "Aggregate signals that fed into the status computation.",
          "properties": {
            "open_work_items": {
              "type": "integer",
              "minimum": 0
            },
            "runnable_work_items": {
              "type": "integer",
              "minimum": 0
            },
            "active_agent_runs": {
              "type": "integer",
              "minimum": 0
            },
            "open_blockers": {
              "type": "integer",
              "minimum": 0
            },
            "last_progress_at": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        "policy": {
          "type": "object",
          "description": "Alerting and evaluation policy for this lifecycle.",
          "properties": {
            "progress_expected": {
              "type": "boolean"
            },
            "alerts_enabled": {
              "type": "boolean"
            },
            "silence_if_status_in": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      },
      "required": [
        "lifecycle_id",
        "repo",
        "previous",
        "current"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "type",
    "kind",
    "domain",
    "data"
  ]
}
