{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/lifecycle/status.updated.v1.json",
  "title": "Authoritative Lifecycle Status Updated Event",
  "description": "An outbox-published status or health transition computed by the standalone delorenj/lifecycle authority. On the initial state_version=1 publication, previous and previous_state_version are null; later publications require both prior values. repo remains mandatory and non-empty on every publication.",
  "type": "object",
  "allOf": [
    { "$ref": "../../../_common/cloudevent_base.v1.json" }
  ],
  "properties": {
    "type": { "const": "bloodbank.v1.lifecycle.status.updated" },
    "kind": { "const": "event" },
    "domain": { "const": "lifecycle" },
    "subject": { "const": "bloodbank.evt.v1.lifecycle.status.updated" },
    "datacontenttype": { "const": "application/json" },
    "dataschema": {
      "const": "apicurio://holyfields/bloodbank.v1.lifecycle.status.updated/versions/1"
    },
    "schemaref": { "const": "bloodbank.v1.lifecycle.status.updated.v1" },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "contract_version": { "const": 1 },
        "lifecycle_id": { "type": "string", "minLength": 1 },
        "repo": { "type": "string", "minLength": 1 },
        "spec_version": { "type": "integer", "minimum": 1 },
        "state_version": { "type": "integer", "minimum": 1 },
        "previous_state_version": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "previous": {
          "oneOf": [
            { "$ref": "../../../_common/lifecycle_contracts.v1.json#/$defs/state_summary" },
            { "type": "null" }
          ]
        },
        "current": {
          "$ref": "../../../_common/lifecycle_contracts.v1.json#/$defs/state_summary"
        },
        "transition": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "reason": { "type": "string", "minLength": 1 },
            "computed": { "const": true },
            "detector": { "type": "string", "minLength": 1 },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
          },
          "required": ["reason", "computed", "detector"]
        },
        "blockers": {
          "type": "array",
          "items": {
            "$ref": "../../../_common/lifecycle_contracts.v1.json#/$defs/blocker"
          }
        },
        "signals": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "open_work_items": { "type": "integer", "minimum": 0 },
            "runnable_work_items": { "type": "integer", "minimum": 0 },
            "active_agent_runs": { "type": "integer", "minimum": 0 },
            "open_blockers": { "type": "integer", "minimum": 0 },
            "last_progress_at": {
              "oneOf": [
                { "$ref": "../../../_common/types.v1.json#/$defs/timestamp" },
                { "type": "null" }
              ]
            }
          },
          "required": [
            "open_work_items",
            "runnable_work_items",
            "active_agent_runs",
            "open_blockers",
            "last_progress_at"
          ]
        },
        "provenance": {
          "$ref": "../../../_common/lifecycle_contracts.v1.json#/$defs/provenance"
        },
        "freshness": {
          "$ref": "../../../_common/lifecycle_contracts.v1.json#/$defs/freshness"
        },
        "publication": {
          "$ref": "../../../_common/lifecycle_contracts.v1.json#/$defs/publication"
        }
      },
      "required": [
        "contract_version",
        "lifecycle_id",
        "repo",
        "spec_version",
        "state_version",
        "previous_state_version",
        "previous",
        "current",
        "transition",
        "blockers",
        "provenance",
        "freshness",
        "publication"
      ],
      "allOf": [
        {
          "if": {
            "properties": { "state_version": { "const": 1 } },
            "required": ["state_version"]
          },
          "then": {
            "properties": {
              "previous_state_version": { "type": "null" },
              "previous": { "type": "null" }
            }
          },
          "else": {
            "properties": {
              "previous_state_version": { "type": "integer", "minimum": 1 },
              "previous": {
                "$ref": "../../../_common/lifecycle_contracts.v1.json#/$defs/state_summary"
              }
            }
          }
        }
      ]
    }
  },
  "required": [
    "specversion",
    "id",
    "source",
    "type",
    "subject",
    "time",
    "datacontenttype",
    "dataschema",
    "correlationid",
    "causationid",
    "producer",
    "service",
    "kind",
    "domain",
    "schemaref",
    "actor",
    "ordering_key",
    "data"
  ]
}
