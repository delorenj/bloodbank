{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/lifecycle/obligation_evidence.submitted.v1.json",
  "title": "Lifecycle Obligation Completion Evidence Submitted Event",
  "description": "Canonical completed-skill evidence submitted to Lifecycle for an exact authority obligation. This event reports actor work; only Lifecycle decides whether it satisfies the obligation or changes lifecycle truth.",
  "type": "object",
  "allOf": [
    { "$ref": "../../../_common/cloudevent_base.v1.json" }
  ],
  "properties": {
    "type": { "const": "bloodbank.v1.lifecycle.obligation_evidence.submitted" },
    "kind": { "const": "event" },
    "domain": { "const": "lifecycle" },
    "subject": { "const": "bloodbank.evt.v1.lifecycle.obligation_evidence.submitted" },
    "datacontenttype": { "const": "application/json" },
    "dataschema": {
      "const": "apicurio://holyfields/bloodbank.v1.lifecycle.obligation_evidence.submitted/versions/1"
    },
    "schemaref": { "const": "bloodbank.v1.lifecycle.obligation_evidence.submitted.v1" },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "contract_version": { "const": 1 },
        "lifecycle_id": { "type": "string", "minLength": 1 },
        "repo": { "type": "string", "minLength": 1 },
        "obligation_id": { "type": "string", "minLength": 1 },
        "obligation_kind": { "type": "string", "minLength": 1 },
        "target_actor_id": { "type": "string", "minLength": 1 },
        "invocation_id": { "$ref": "../../../_common/types.v1.json#/$defs/uuid" },
        "skill_ref": {
          "$ref": "../../../_common/lifecycle_contracts.v1.json#/$defs/skill_ref"
        },
        "completed_at": { "$ref": "../../../_common/types.v1.json#/$defs/timestamp" },
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "skill_completion" },
            "outcome": { "const": "completed" },
            "artifact_id": { "type": "string", "minLength": 1 },
            "artifact_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
            "summary": { "type": "string", "minLength": 1, "maxLength": 500 }
          },
          "required": [
            "kind",
            "outcome",
            "artifact_id",
            "artifact_sha256",
            "summary"
          ]
        }
      },
      "required": [
        "contract_version",
        "lifecycle_id",
        "repo",
        "obligation_id",
        "obligation_kind",
        "target_actor_id",
        "invocation_id",
        "skill_ref",
        "completed_at",
        "evidence"
      ]
    }
  },
  "required": [
    "specversion",
    "id",
    "source",
    "type",
    "subject",
    "time",
    "datacontenttype",
    "dataschema",
    "correlationid",
    "causationid",
    "producer",
    "service",
    "kind",
    "domain",
    "schemaref",
    "actor",
    "ordering_key",
    "data"
  ]
}
