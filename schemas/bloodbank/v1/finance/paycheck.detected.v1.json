{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/finance/paycheck.detected.v1.json",
  "title": "Finance Paycheck Detected Event",
  "description": "An income deposit matching a payday pattern landed. Producer: tiller. See bloodbank/docs/event-naming.md.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.finance.paycheck.detected"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "finance"
    },
    "data": {
      "type": "object",
      "description": "Payload for bloodbank.v1.finance.paycheck.detected.",
      "properties": {
        "txn_id": {
          "type": "string",
          "minLength": 1
        },
        "amount_cents": {
          "type": "integer"
        },
        "posted_on": {
          "type": "string",
          "format": "date",
          "minLength": 1
        },
        "next_expected": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "txn_id",
        "amount_cents"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "type",
    "kind",
    "domain",
    "data"
  ]
}
