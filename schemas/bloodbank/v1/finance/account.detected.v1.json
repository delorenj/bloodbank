{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/finance/account.detected.v1.json",
  "title": "Finance Account Detected Event",
  "description": "Account auto-discovery inserted a new tracked account. Producer: tiller. See bloodbank/docs/event-naming.md.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.finance.account.detected"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "finance"
    },
    "data": {
      "type": "object",
      "description": "Payload for bloodbank.v1.finance.account.detected.",
      "properties": {
        "account_id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "institution": {
          "type": [
            "string",
            "null"
          ]
        },
        "class": {
          "type": "string",
          "enum": [
            "asset",
            "liability"
          ]
        },
        "kind": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "account_id",
        "name"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "type",
    "kind",
    "domain",
    "data"
  ]
}
