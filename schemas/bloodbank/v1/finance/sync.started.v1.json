{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/finance/sync.started.v1.json",
  "title": "Finance Sync Started Event",
  "description": "A tiller sheet-to-Postgres sync run opened. Producer: tiller. See bloodbank/docs/event-naming.md.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.finance.sync.started"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "finance"
    },
    "data": {
      "type": "object",
      "description": "Payload for bloodbank.v1.finance.sync.started.",
      "properties": {
        "run_id": {
          "type": "integer"
        },
        "trigger": {
          "type": "string",
          "enum": [
            "cron",
            "manual",
            "csv",
            "seed"
          ]
        }
      },
      "required": [
        "run_id",
        "trigger"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "type",
    "kind",
    "domain",
    "data"
  ]
}
