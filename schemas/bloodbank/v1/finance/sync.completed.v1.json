{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/finance/sync.completed.v1.json",
  "title": "Finance Sync Completed Event",
  "description": "A tiller sync run finished with ingest/detector counts. Producer: tiller. See bloodbank/docs/event-naming.md.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.finance.sync.completed"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "finance"
    },
    "data": {
      "type": "object",
      "description": "Payload for bloodbank.v1.finance.sync.completed.",
      "properties": {
        "run_id": {
          "type": "integer"
        },
        "status": {
          "type": "string",
          "enum": [
            "success",
            "partial"
          ]
        },
        "trigger": {
          "type": "string",
          "minLength": 1
        },
        "txns_seen": {
          "type": "integer"
        },
        "txns_inserted": {
          "type": "integer"
        },
        "txns_updated": {
          "type": "integer"
        },
        "balances_seen": {
          "type": "integer"
        },
        "balances_upserted": {
          "type": "integer"
        },
        "accounts_discovered": {
          "type": "integer"
        },
        "series_created": {
          "type": "integer"
        },
        "series_updated": {
          "type": "integer"
        },
        "zombies_detected": {
          "type": "integer"
        },
        "duration_ms": {
          "type": "integer"
        }
      },
      "required": [
        "run_id",
        "status"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "type",
    "kind",
    "domain",
    "data"
  ]
}
