{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/finance/subscription.detected.v1.json",
  "title": "Finance Subscription Detected Event",
  "description": "The recurring detector found a new charge/income series. Producer: tiller. See bloodbank/docs/event-naming.md.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.finance.subscription.detected"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "finance"
    },
    "data": {
      "type": "object",
      "description": "Payload for bloodbank.v1.finance.subscription.detected.",
      "properties": {
        "series_id": {
          "type": "string",
          "minLength": 1
        },
        "merchant": {
          "type": "string",
          "minLength": 1
        },
        "cadence": {
          "type": "string",
          "minLength": 1
        },
        "typical_cents": {
          "type": "integer"
        },
        "direction": {
          "type": "string",
          "enum": [
            "debit",
            "credit"
          ]
        },
        "occurrences": {
          "type": "integer"
        }
      },
      "required": [
        "series_id",
        "merchant",
        "cadence"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "type",
    "kind",
    "domain",
    "data"
  ]
}
