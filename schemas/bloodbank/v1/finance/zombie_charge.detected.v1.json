{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/finance/zombie_charge.detected.v1.json",
  "title": "Finance Zombie Charge Detected Event",
  "description": "A charge landed on a series the owner already canceled \u2014 a zombie strike. Producer: tiller. See bloodbank/docs/event-naming.md.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.finance.zombie_charge.detected"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "finance"
    },
    "data": {
      "type": "object",
      "description": "Payload for bloodbank.v1.finance.zombie_charge.detected.",
      "properties": {
        "series_id": {
          "type": "string",
          "minLength": 1
        },
        "txn_id": {
          "type": "string",
          "minLength": 1
        },
        "amount_cents": {
          "type": "integer"
        },
        "strike_count": {
          "type": "integer"
        },
        "total_stolen_cents": {
          "type": "integer"
        },
        "posted_on": {
          "type": "string",
          "format": "date",
          "minLength": 1
        }
      },
      "required": [
        "series_id",
        "txn_id",
        "amount_cents",
        "strike_count"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "type",
    "kind",
    "domain",
    "data"
  ]
}
