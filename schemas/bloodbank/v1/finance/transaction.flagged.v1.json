{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/finance/transaction.flagged.v1.json",
  "title": "Finance Transaction Flagged Event",
  "description": "A transaction was flagged for review (by the operator or a rule such as large_unknown_charge). Producer: tiller. See bloodbank/docs/event-naming.md.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.finance.transaction.flagged"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "finance"
    },
    "data": {
      "type": "object",
      "description": "Payload for bloodbank.v1.finance.transaction.flagged.",
      "properties": {
        "txn_id": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "amount_cents": {
          "type": "integer"
        },
        "merchant": {
          "type": "string",
          "minLength": 1
        },
        "posted_on": {
          "type": "string",
          "format": "date",
          "minLength": 1
        },
        "by": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "txn_id",
        "reason"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "type",
    "kind",
    "domain",
    "data"
  ]
}
