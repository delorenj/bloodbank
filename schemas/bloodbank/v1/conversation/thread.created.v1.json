{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/conversation/thread.created.v1.json",
  "title": "Conversation Thread Created Event",
  "description": "A conversation thread was created. Emitted on the first turn of a new thread. See bloodbank/docs/event-naming.md.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.conversation.thread.created"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "conversation"
    },
    "data": {
      "type": "object",
      "description": "Payload for bloodbank.v1.conversation.thread.created.",
      "properties": {
        "thread_id": {
          "type": "string",
          "minLength": 1,
          "description": "Stable thread identifier."
        }
      },
      "required": [
        "thread_id"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "type",
    "kind",
    "domain",
    "data"
  ]
}
