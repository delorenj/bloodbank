{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/conversation/message.appended.v1.json",
  "title": "Conversation Message Appended Event",
  "description": "A message was appended to the durable conversation transcript. See bloodbank/docs/event-naming.md.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.conversation.message.appended"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "conversation"
    },
    "data": {
      "type": "object",
      "description": "Payload for bloodbank.v1.conversation.message.appended.",
      "properties": {
        "thread_id": {
          "type": "string",
          "minLength": 1
        },
        "turn_id": {
          "type": "string",
          "minLength": 1
        },
        "message_id": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "enum": [
            "user",
            "assistant",
            "system",
            "tool"
          ]
        },
        "text": {
          "type": [
            "string",
            "null"
          ],
          "description": "Plaintext rendering of the message. May be omitted for privacy."
        }
      },
      "required": [
        "thread_id",
        "turn_id",
        "message_id",
        "role"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "type",
    "kind",
    "domain",
    "data"
  ]
}
