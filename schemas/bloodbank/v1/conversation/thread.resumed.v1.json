{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/conversation/thread.resumed.v1.json",
  "title": "Conversation Thread Resumed Event",
  "description": "A known conversation thread was reopened. See bloodbank/docs/event-naming.md.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.conversation.thread.resumed"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "conversation"
    },
    "data": {
      "type": "object",
      "description": "Payload for bloodbank.v1.conversation.thread.resumed.",
      "properties": {
        "thread_id": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "thread_id"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "type",
    "kind",
    "domain",
    "data"
  ]
}
