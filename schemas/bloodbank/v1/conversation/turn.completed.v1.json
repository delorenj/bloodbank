{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://33god.dev/schemas/bloodbank/v1/conversation/turn.completed.v1.json",
  "title": "Conversation Turn Completed Event",
  "description": "A turn reached a terminal state. See bloodbank/docs/event-naming.md.",
  "type": "object",
  "allOf": [
    {
      "$ref": "../../../_common/cloudevent_base.v1.json"
    }
  ],
  "properties": {
    "type": {
      "const": "bloodbank.v1.conversation.turn.completed"
    },
    "kind": {
      "const": "event"
    },
    "domain": {
      "const": "conversation"
    },
    "data": {
      "type": "object",
      "description": "Payload for bloodbank.v1.conversation.turn.completed.",
      "properties": {
        "thread_id": {
          "type": "string",
          "minLength": 1
        },
        "turn_id": {
          "type": "string",
          "minLength": 1
        },
        "outcome": {
          "type": "string",
          "enum": [
            "completed",
            "failed",
            "canceled"
          ],
          "description": "Terminal disposition of the turn."
        }
      },
      "required": [
        "thread_id",
        "turn_id",
        "outcome"
      ],
      "additionalProperties": true
    }
  },
  "required": [
    "type",
    "kind",
    "domain",
    "data"
  ]
}
