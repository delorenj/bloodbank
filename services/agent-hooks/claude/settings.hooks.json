{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.local/bin/mise x -- python /home/delorenj/.agents/hooks/bloodbank/publish.py --client claude --hook session-start",
            "timeout": 3
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat | $HOME/.local/bin/mise x -- python /home/delorenj/.agents/hooks/bloodbank/publish.py --client claude --hook prompt-submitted",
            "timeout": 3
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "cat | $HOME/.local/bin/mise x -- python /home/delorenj/.agents/hooks/bloodbank/publish.py --client claude --hook tool-request",
            "timeout": 3
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "cat | $HOME/.local/bin/mise x -- python /home/delorenj/.agents/hooks/bloodbank/publish.py --client claude --hook tool-action",
            "timeout": 3
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat | $HOME/.local/bin/mise x -- python /home/delorenj/.agents/hooks/bloodbank/publish.py --client claude --hook subagent-stopped",
            "timeout": 3
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat | $HOME/.local/bin/mise x -- python /home/delorenj/.agents/hooks/bloodbank/publish.py --client claude --hook session-end",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
