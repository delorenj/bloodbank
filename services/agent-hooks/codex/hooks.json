{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{}' | python3 /home/delorenj/.agents/hooks/bloodbank/publish.py --client codex --hook SessionStart",
            "timeout": 3000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{}' | python3 /home/delorenj/.agents/hooks/bloodbank/publish.py --client codex --hook Stop user_stop",
            "timeout": 3000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat | python3 /home/delorenj/.agents/hooks/bloodbank/publish.py --client codex --hook UserPromptSubmit",
            "timeout": 3000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "cat | python3 /home/delorenj/.agents/hooks/bloodbank/publish.py --client codex --hook PreToolUse",
            "timeout": 3000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "cat | python3 /home/delorenj/.agents/hooks/bloodbank/publish.py --client codex --hook PostToolUse",
            "timeout": 3000
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat | python3 /home/delorenj/.agents/hooks/bloodbank/publish.py --client codex --hook SubagentStart",
            "timeout": 3000
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat | python3 /home/delorenj/.agents/hooks/bloodbank/publish.py --client codex --hook SubagentStop",
            "timeout": 3000
          }
        ]
      }
    ]
  }
}
