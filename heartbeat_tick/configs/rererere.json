{
  "$schema": "heartbeat.v1",
  "agent": "rererere",
  "role": "intelliforia-lead",
  "checks": {
    "pr_review": {
      "cadenceMs": 3600000,
      "window": {"start": "08:00", "end": "22:00", "tz": "America/New_York"},
      "lastRun": 0,
      "priority": 1,
      "handler": "pr_review",
      "enabled": true,
      "description": "Check open PRs on trinote2.0 for review requests or CI failures"
    },
    "trunk_health": {
      "cadenceMs": 7200000,
      "window": {"start": "00:00", "end": "23:59", "tz": "America/New_York"},
      "lastRun": 0,
      "priority": 2,
      "handler": "trunk_health",
      "enabled": true,
      "description": "Check trunk-main for merge conflicts, stale branches, CI status"
    }
  },
  "paused": {}
}
